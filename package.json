{
  "name": "astro-md-editor",
  "version": "0.0.8",
  "description": "Schema-aware editor for Astro content collections.",
  "author": "Bibek Timsina",
  "license": "MIT",
  "keywords": [
    "astro",
    "markdown",
    "mdx",
    "content-collections",
    "editor",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bimsina/astro-md-editor.git"
  },
  "homepage": "https://github.com/bimsina/astro-md-editor#readme",
  "bugs": {
    "url": "https://github.com/bimsina/astro-md-editor/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "private": false,
  "type": "module",
  "bin": {
    "astro-md-editor": "./index.mjs"
  },
  "files": [
    ".output/",
    "index.mjs",
    "scripts/bootstrap-collections.mjs",
    "README.md",
    "LICENSE.md"
  ],
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs --path example-blog --port 3000",
    "build": "vite build",
    "start": "node index.mjs",
    "preview": "vite preview",
    "lint": "eslint",
    "format": "prettier --write .",
    "check": "prettier --write . && eslint --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.9.10",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-devtools": "^1.166.2",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/router-plugin": "^1.132.0",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/turndown": "^5.0.6",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "motion": "^12.35.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.7.1",
    "shadcn": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.7.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "^0.5.3",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "msw",
      "unrs-resolver"
    ]
  }
}
